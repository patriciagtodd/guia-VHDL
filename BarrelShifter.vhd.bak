architecture estructural of BarrelShifter is

    component muxNbit
        generic(N : integer := 8);
        port(
            a : in  bit_vector(0 to N-1);
            b : in  bit_vector(0 to N-1);
            s : in  bit;
            y : out bit_vector(0 to N-1)
        );
    end component;

    signal t1, t2 : bit_vector(0 to N-1);
    signal sh1, sh2, sh4 : bit_vector(0 to N-1);

begin

    -- Shift 1: siempre desde 'a' (no depende de nadie)
    sh1(0 to N-2) <= a(1 to N-1);
    sh1(N-1)      <= '0';

    -- Shift 2: desde t1 (sale del Mux1) ? necesita proceso
    process(t1)
    begin
        sh2 <= (others => '0');
        sh2(0 to N-3) <= t1(2 to N-1);
    end process;

    -- Shift 4: desde t2 (sale del Mux2) ? necesita proceso
    process(t2)
    begin
        sh4 <= (others => '0');
        sh4(0 to N-5) <= t2(4 to N-1);
    end process;

    -- Mux 1: s(0) controla shift de 1
    Mx1 : muxNbit
        generic map(N)
        port map(a => a, b => sh1, s => s(0), y => t1);

    -- Mux 2: s(1) controla shift de 2
    Mx2 : muxNbit
        generic map(N)
        port map(a => t1, b => sh2, s => s(1), y => t2);

    -- Mux 3: s(2) controla shift de 4
    Mx3 : muxNbit
        generic map(N)
        port map(a => t2, b => sh4, s => s(2), y => y);

end estructural;